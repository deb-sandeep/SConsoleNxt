					"code": "CREATE\n\tDEFINER = 'root'@'localhost'\nVIEW sconsolenxt.today_solved_problem_count\nAS\nselect `pa`.`topic_id` AS `topic_id`,count(`pa`.`problem_id`) AS `num_solved_problems` from (select `sconsolenxt`.`problem_attempt`.`problem_id` AS `problem_id`,`sconsolenxt`.`problem_attempt`.`topic_id` AS `topic_id`,`sconsolenxt`.`problem_attempt`.`target_state` AS `target_state`,row_number() OVER (PARTITION BY `sconsolenxt`.`problem_attempt`.`problem_id` ORDER BY `sconsolenxt`.`problem_attempt`.`end_time` desc )  AS `row_num` from `sconsolenxt`.`problem_attempt` where (`sconsolenxt`.`problem_attempt`.`end_time` between curdate() and (curdate() + interval 1 day))) `pa` where ((`pa`.`row_num` = 1) and (`pa`.`target_state` in ('Correct','Incorrect','Pigeon Explained','Purge'))) group by `pa`.`topic_id` order by `pa`.`topic_id`\n;",
