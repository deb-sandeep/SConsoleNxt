		"8a1343dd-1ca5-41dc-bfd9-18efb4b69e49": {
			"code": "CREATE\n\tDEFINER = 'root'@'localhost'\nVIEW sconsolenxt.latest_problem_state\nAS\nselect `pa`.`problem_id` AS `problem_id`,`pa`.`target_state` AS `state`,`pa`.`end_time` AS `last_attempt_time`,`pa`.`total_duration` AS `total_duration`,`pa`.`num_attempts` AS `num_attempts` from (select `sconsolenxt`.`problem_attempt`.`problem_id` AS `problem_id`,`sconsolenxt`.`problem_attempt`.`target_state` AS `target_state`,`sconsolenxt`.`problem_attempt`.`end_time` AS `end_time`,row_number() OVER (PARTITION BY `sconsolenxt`.`problem_attempt`.`problem_id` ORDER BY `sconsolenxt`.`problem_attempt`.`start_time` desc )  AS `row_num`,sum(`sconsolenxt`.`problem_attempt`.`effective_duration`) OVER (PARTITION BY `sconsolenxt`.`problem_attempt`.`problem_id` )  AS `total_duration`,count(`sconsolenxt`.`problem_attempt`.`id`) OVER (PARTITION BY `sconsolenxt`.`problem_attempt`.`problem_id` )  AS `num_attempts` from `sconsolenxt`.`problem_attempt`) `pa` where (`pa`.`row_num` = 1) order by `pa`.`problem_id`\n;",
			"id": "8a1343dd-1ca5-41dc-bfd9-18efb4b69e49",
			"name": "latest_problem_state",
			"desc": "",
			"lines": [],
			"type": "View",
			"visible": false,
			"generateCustomCode": true,
			"generate": true,
			"customCode": "",
			"typeExpression": ""
		},
		"0563d385-3146-42f1-b4c3-4861a51f61d2": {
			"code": "CREATE\n\tDEFINER = 'root'@'localhost'\nVIEW sconsolenxt.question_repo_status\nAS\nselect `q`.`syllabus_name` AS `syllabus_name`,`q`.`topic_id` AS `topic_id`,`t`.`topic_name` AS `topic_name`,`q`.`problem_type` AS `problem_type`,(case when (`eq`.`id` is null) then 'UNASSIGNED' when (`eqa`.`id` is null) then 'ASSIGNED' else 'ATTEMPTED' end) AS `question_status`,count(`q`.`id`) AS `count` from (((`sconsolenxt`.`question` `q` left join `sconsolenxt`.`topic_master` `t` on((`q`.`topic_id` = `t`.`id`))) left join `sconsolenxt`.`exam_question` `eq` on((`q`.`id` = `eq`.`question_id`))) left join `sconsolenxt`.`exam_question_attempt` `eqa` on((`eq`.`id` = `eqa`.`exam_question_id`))) group by `q`.`syllabus_name`,`q`.`topic_id`,`t`.`topic_name`,`q`.`problem_type`,(case when (`eq`.`id` is null) then 'UNASSIGNED' when (`eqa`.`id` is null) then 'ASSIGNED' else 'ATTEMPTED' end) order by `q`.`syllabus_name`,`q`.`topic_id`,`q`.`problem_type`,(case when (`eq`.`id` is null) then 'UNASSIGNED' when (`eqa`.`id` is null) then 'ASSIGNED' else 'ATTEMPTED' end)\n;",
			"id": "0563d385-3146-42f1-b4c3-4861a51f61d2",
			"name": "question_repo_status",
			"desc": "",
			"lines": [],
			"type": "View",
			"visible": true,
			"generateCustomCode": true,
			"generate": true,
			"customCode": "",
			"typeExpression": ""
		},
		"ee092d88-1146-48a5-a507-9b1e7ae62fa7": {
			"code": "CREATE\n\tDEFINER = 'root'@'localhost'\nVIEW sconsolenxt.today_solved_problem_count\nAS\nselect `pa`.`topic_id` AS `topic_id`,count(`pa`.`problem_id`) AS `num_solved_problems` from (select `sconsolenxt`.`problem_attempt`.`problem_id` AS `problem_id`,`sconsolenxt`.`problem_attempt`.`topic_id` AS `topic_id`,`sconsolenxt`.`problem_attempt`.`target_state` AS `target_state`,row_number() OVER (PARTITION BY `sconsolenxt`.`problem_attempt`.`problem_id` ORDER BY `sconsolenxt`.`problem_attempt`.`end_time` desc )  AS `row_num` from `sconsolenxt`.`problem_attempt` where (`sconsolenxt`.`problem_attempt`.`end_time` between curdate() and (curdate() + interval 1 day))) `pa` where ((`pa`.`row_num` = 1) and (`pa`.`target_state` in ('Correct','Incorrect','Pigeon Explained','Purge'))) group by `pa`.`topic_id` order by `pa`.`topic_id`\n;",
			"id": "ee092d88-1146-48a5-a507-9b1e7ae62fa7",
			"name": "today_solved_problem_count",
			"desc": "",
			"lines": [],
			"type": "View",
			"visible": false,
			"generateCustomCode": true,
			"generate": true,
			"customCode": "",
			"typeExpression": ""
		},
		"60b1f164-9927-4b45-85dc-366ca337d34a": {
			"code": "CREATE\n\tDEFINER = 'root'@'localhost'\nVIEW sconsolenxt.topic_problems\nAS\nselect `tcm`.`topic_id` AS `topic_id`,`t`.`syllabus_name` AS `syllabus_name`,`t`.`section` AS `topic_section`,`t`.`topic_name` AS `topic_name`,`p`.`book_id` AS `book_id`,`b`.`book_short_name` AS `book_short_name`,`b`.`series_name` AS `book_series`,`p`.`chapter_num` AS `chapter_num`,`c`.`chapter_name` AS `chapter_name`,`p`.`id` AS `problem_id`,`p`.`exercise_num` AS `exercise_num`,`p`.`exercise_name` AS `exercise_name`,`p`.`problem_type` AS `problem_type`,`p`.`problem_key` AS `problem_key`,`p`.`difficulty_level` AS `difficulty_level`,(case when (`sconsolenxt`.`ps`.`state` is null) then 'Assigned' else `sconsolenxt`.`ps`.`state` end) AS `problem_state`,`sconsolenxt`.`ps`.`last_attempt_time` AS `last_attempt_time`,(case when (`sconsolenxt`.`ps`.`total_duration` is null) then 0 else `sconsolenxt`.`ps`.`total_duration` end) AS `total_duration`,(case when (`sconsolenxt`.`ps`.`num_attempts` is null) then 0 else `sconsolenxt`.`ps`.`num_attempts` end) AS `num_attempts` from ((((((`sconsolenxt`.`problem_master` `p` left join `sconsolenxt`.`topic_chapter_problem_map` `tcpm` on((`p`.`id` = `tcpm`.`problem_id`))) left join `sconsolenxt`.`topic_chapter_map` `tcm` on((`tcpm`.`topic_chapter_map_id` = `tcm`.`id`))) left join `sconsolenxt`.`topic_master` `t` on((`tcm`.`topic_id` = `t`.`id`))) left join `sconsolenxt`.`book_master` `b` on((`tcm`.`book_id` = `b`.`id`))) left join `sconsolenxt`.`chapter_master` `c` on(((`tcm`.`book_id` = `c`.`book_id`) and (`tcm`.`chapter_num` = `c`.`chapter_num`)))) left join `sconsolenxt`.`latest_problem_state` `ps` on((`p`.`id` = `sconsolenxt`.`ps`.`problem_id`))) where (`tcm`.`topic_id` is not null) order by `tcm`.`topic_id`,`tcm`.`attempt_seq`,`p`.`id`\n;",
			"id": "60b1f164-9927-4b45-85dc-366ca337d34a",
			"name": "topic_problems",
			"desc": "",
			"lines": [],
			"type": "View",
