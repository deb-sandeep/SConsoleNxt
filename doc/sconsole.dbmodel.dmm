	"otherObjects": {
		"3e5908c2-2832-4fab-abaf-266952aa60ba": {
			"code": "CREATE\n\tDEFINER = 'root'@'localhost'\nVIEW sconsolenxt.day_syllabus_total_study_time\nAS\nselect `day_study_time`.`date` AS `date`,`day_study_time`.`syllabus_name` AS `syllabus_name`,sum(`day_study_time`.`effective_duration`) AS `total_time` from (select cast(`sconsolenxt`.`session`.`end_time` as date) AS `date`,`sconsolenxt`.`session`.`syllabus_name` AS `syllabus_name`,`sconsolenxt`.`session`.`effective_duration` AS `effective_duration` from `sconsolenxt`.`session`) `day_study_time` group by `day_study_time`.`date`,`day_study_time`.`syllabus_name` order by `day_study_time`.`date`,`day_study_time`.`syllabus_name`\n;",
			"id": "3e5908c2-2832-4fab-abaf-266952aa60ba",
			"name": "day_syllabus_total_study_time",
			"desc": "",
			"lines": [],
			"type": "View",
			"visible": false,
			"generateCustomCode": true,
			"generate": true,
			"customCode": "",
			"typeExpression": ""
		},
		"5fd34dc8-b1f2-47c4-90bf-3ed356cf57e3": {
			"code": "CREATE\n\tDEFINER = 'root'@'localhost'\nVIEW sconsolenxt.day_topic_num_solved_problems\nAS\nselect `day_counts`.`date` AS `date`,`day_counts`.`topic_id` AS `topic_id`,count(`day_counts`.`problem_id`) AS `num_solved_problems` from (select `pa`.`date` AS `date`,`pa`.`topic_id` AS `topic_id`,`pa`.`problem_id` AS `problem_id`,`pa`.`target_state` AS `target_state` from (select cast(`sconsolenxt`.`problem_attempt`.`end_time` as date) AS `date`,`sconsolenxt`.`problem_attempt`.`topic_id` AS `topic_id`,`sconsolenxt`.`problem_attempt`.`problem_id` AS `problem_id`,`sconsolenxt`.`problem_attempt`.`target_state` AS `target_state`,row_number() OVER (PARTITION BY `sconsolenxt`.`problem_attempt`.`problem_id` ORDER BY `sconsolenxt`.`problem_attempt`.`start_time` desc )  AS `row_num` from `sconsolenxt`.`problem_attempt`) `pa` where (`pa`.`row_num` = 1)) `day_counts` where (`day_counts`.`target_state` in ('Correct','Incorrect','Pigeon Explained','Purge')) group by `day_counts`.`date`,`day_counts`.`topic_id` order by `day_counts`.`date` desc\n;",
			"id": "5fd34dc8-b1f2-47c4-90bf-3ed356cf57e3",
			"name": "day_topic_num_solved_problems",
			"desc": "",
			"lines": [],
			"type": "View",
			"visible": false,
			"generateCustomCode": true,
			"generate": true,
			"customCode": "",
			"typeExpression": ""
		},
		"d47e6e55-ef57-4e2b-b39a-dc6dce1c7d95": {
			"code": "CREATE\n\tDEFINER = 'root'@'localhost'\nVIEW sconsolenxt.day_total_study_time\nAS\nselect `day_study_time`.`date` AS `date`,sum(`day_study_time`.`effective_duration`) AS `total_time` from (select cast(`sconsolenxt`.`session`.`end_time` as date) AS `date`,`sconsolenxt`.`session`.`effective_duration` AS `effective_duration` from `sconsolenxt`.`session`) `day_study_time` group by `day_study_time`.`date` order by `day_study_time`.`date`\n;",
			"id": "d47e6e55-ef57-4e2b-b39a-dc6dce1c7d95",
			"name": "day_total_study_time",
			"desc": "",
